# 企业微信集成 Docker 环境变量配置
# 复制此文件为 .env 并填写实际值

# 企业微信应用配置
WECOM_CORP_ID=your_corp_id_here
WECOM_CORP_SECRET=your_corp_secret_here
WECOM_AGENT_ID=your_agent_id_here

# 企业微信功能开关
WECOM_SYNC_ENABLED=true
WECOM_NOTIFICATION_ENABLED=true

# Redis 配置（可选，用于缓存）
REDIS_PASSWORD=svnadmin123

# MySQL 配置（可选，替代 SQLite）
MYSQL_ROOT_PASSWORD=svnadmin123
MYSQL_DATABASE=svnadmin
MYSQL_USER=svnadmin
MYSQL_PASSWORD=svnadmin123

# 时区设置
TZ=Asia/Shanghai
